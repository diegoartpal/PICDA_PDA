#set("y", hWG/2);
#set("z", z_wg);
#set("x span", LC + LC+2*LS+LWG);
#set("y span", y_coup + 2*wWG + 2*dS + 1e-6);

# Run
run;
emepropagate;

S = getresult("EME", "user s matrix");
T11 = abs(S(1,1))^2;
T21 = abs(S(2,1))^2;
T31 = abs(S(3,1))^2;
T41 = abs(S(4,1))^2;
split3 = T31/(T31 + T41);
split4 = T41/(T31 + T41);
